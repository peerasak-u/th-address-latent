{
  "name": "th-address-latent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.5",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "vite",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
